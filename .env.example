# Google Gemini API key used by /api/generate (server-side only — never exposed to the client).
# Get one at https://aistudio.google.com/apikey then copy this file to `.env.local`:
#   cp .env.example .env.local
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — pin ONE Gemini model globally, overriding the in-app model selector
# (which otherwise lets you choose Flash Lite / Flash / Pro; default is Flash Lite).
# GEMINI_MODEL=gemini-2.5-flash
